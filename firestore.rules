rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprints
    function isValidUser(data) {
      return true;
    }

    function isValidIssue(data) {
      return true;
    }

    function isValidComment(data) {
      return true;
    }

    function isValidNotification(data) {
      return true;
    }

    // Match rules for collections
    match /users/{userId} {
      // Allow read/write for any signed in user
      allow read, write: if isSignedIn();
    }

    match /departments/{departmentId} {
      // Anyone signed in can read departments or write them (seeding)
      allow read, write: if isSignedIn();
    }

    match /issues/{issueId} {
      // Anyone signed in can read and create issues
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;

      // Nested comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      // Nested activityLogs subcollection
      match /activityLogs/{logId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      // Nested verificationRequests subcollection
      match /verificationRequests/{requestId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }
  }
}
